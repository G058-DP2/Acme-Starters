acme.validation.text.message   	    = Debe tener entre 1 y 255 caracteres
acme.validation.header.message   	= Debe tener entre 1 y 75 caracteres
acme.validation.ticker.message 		= El ticker debe comenzar con 2 letras mayúsculas y 2 números, seguidos de un guion y entre 5 y 10 caracteres alfanuméricos
acme.validation.sponsorship.donations.error = Un patrocinio no puede publicarse a menos que tenga al menos una donación
acme.validation.sponsorship.dates.error = Los momentos de inicio y fin deben formar un intervalo de tiempo válido en el futuro al momento de la publicación
acme.validation.sponsorship.ticker.non-unique = El ticker ya está siendo utilizado por otro patrocinio
acme.validation.sponsorship.startMoment.future     = La fecha de inicio debe estar en el futuro
acme.validation.sponsorship.endMoment.future       = La fecha de fin debe estar en el futuro
acme.validation.money.eur.error = La moneda debe ser exclusivamente EUR
acme.validation.money.amount.error = La cantidad de dinero debe ser positiva
acme.validation.invention.dates.error = El momento final debe ser posterior al momento inicial
acme.validation.invention.dates.error-publish = Para publicar un invento, ambas fechas deben estar en el futuro
acme.validation.invention.parts.error = Un invento no puede ser publicado a menos que tenga al menos una parte 
acme.validation.invention.ticker.non-unique = El ticker ya está en uso por otro invento
acme.validation.part.cost.error-currency = La divisa debe ser el euro

#Strategy
acme.validation.strategy.duplicated-ticker.message = La Estrategia está duplicada
acme.validation.strategy.tactics.error.message = Una Estrategia no puede publicarse a menos que tenga al menos una táctica
acme.validation.strategy.dates.error = Las fechas de inicio y fin deben definir un intervalo válido de tiempo
acme.validation.strategy.startMoment.future = La fecha de inicio debe estar en el futuro
acme.validation.strategy.endMoment.future = La fecha de fin debe estar en el futuro

acme.validation.tactic.sumPercentages = La suma de los porcentajes de las tácticas tiene que ser menor o igual que 100.00.
##################################### AUDIT 
acme.validation.auditReport.auditSection.error = Los informes de auditoría no se pueden publicar a menos que tengan al menos una sección de auditoría
acme.validation.auditReport.dates.error = Los momentos de inicio y finalización deben formar un intervalo de tiempo válido en el futuro tras la publicación
acme.validation.auditReport.ticker.non-unique = El ticker ya está siendo utilizado por otro informe de auditoría
acme.validation.auditReport.startMoment.future = Start date must be in the future
acme.validation.auditReport.endMoment.future = End date must be in the future
acme.validation.auditReport.auditSections.error.message = Un informe de auditoría no puede publicarse a menos que contenga al menos una sección de auditoría
##################################### CAMPAIGN
acme.validation.campaign.ticker.duplicated = El ticker ya está en uso
acme.validation.campaign.no-milestones = Una campaña no puede publicarse sin al menos un hito
acme.validation.campaign.invalid-interval = Las fechas de inicio y fin deben definir un intervalo válido en el futuro
acme.validation.campaign.effort-not-positive = El esfuerzo total de la campaña debe ser positivo cuando se publique
acme.validation.campaign.startMoment.future     = La fecha de inicio debe estar en el futuro
acme.validation.campaign.endMoment.future       = La fecha de fin debe estar en el futuro
acme.validation.campaign.dates.error-publish = Las fechas de inicio y fin deben definir un intervalo válido de tiempo

##################################### PROJECT
acme.validation.project.no-inventions = Un proyecto no puede publicarse sin al menos un invento
acme.validation.project.invalid-interval = Las fechas de inicio y cierre deben definir un intervalo válido de tiempo
acme.validation.project.kickOffMoment.future  = La fecha de inicio debe estar en el futuro al momento de la publicación
acme.validation.project.closeOutMoment.future = La fecha de cierre debe estar en el futuro al momento de la publicación
acme.validation.project.not-allowed = El proyecto seleccionado no está disponible o no tiene acceso a él
acme.validation.project.unpublishable-component = Uno o más componentes (inventos, campañas o estrategias) no cumplen los requisitos para ser publicados
acme.validation.project.update-not-allowed = El proyecto solo puede asignarse al publicar, no al actualizar o al crear
acme.validation.project.component-out-of-interval = Uno o más intervalos de componentes (inicio/fin) no están contenidos dentro del intervalo del proyecto (kickOff/closeOut)
acme.validation.auditReport.start-before-project-closeout = El momento de inicio del informe de auditoría debe ser posterior al cierre del proyecto
acme.validation.auditReport.project.must-be-published = Los informes de auditoría solo pueden vincularse a proyectos publicados
acme.validation.sponsorship.start-before-project-closeout = El momento de inicio del patrocinio debe ser posterior al cierre del proyecto
acme.validation.sponsorship.project.must-be-published = Los patrocinios solo pueden vincularse a proyectos publicados
